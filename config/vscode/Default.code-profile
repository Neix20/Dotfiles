",\\n\\t\\t\\t\\\"        clsLogger.ErrorLog(ex)\\\\r\\\",\\n\\t\\t\\t\\\"\\\\r\\\",\\n\\t\\t\\t\\\"    return []\\\"\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"description for SQL Select Statment\\\"\\n\\t},\\n\\t\\\"try-catch\\\": {\\n\\t\\t\\\"prefix\\\": \\\"try\\\",\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"try:\\\",\\n\\t\\t\\t\\\"    $TM_SELECTED_TEXT\\\",\\n\\t\\t\\t\\\"except Exception as ex:\\\",\\n\\t\\t\\t\\\"    print(f\\\\\\\"Exception: {ex}\\\\\\\")\\\"\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"description for try-catch\\\"\\n\\t},\\n\\t\\\"Store Procedure Boolean\\\": {\\n\\t\\t\\\"prefix\\\": \\\"store_procedure\\\",\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"def ${STORE_PROCEDURE}(cursor, code):\\\",\\n\\t\\t\\t\\\"    query = \\\\\\\"SET NOCOUNT ON; EXEC ${STORE_PROCEDURE} ?;\\\\\\\"\\\",\\n\\t\\t\\t\\\"    values = (code)\\\",\\n\\t\\t\\t\\\"\\\",\\n\\t\\t\\t\\\"    try:\\\",\\n\\t\\t\\t\\\"        cursor.execute(query, values)\\\",\\n\\t\\t\\t\\\"        cursor.commit()\\\",\\n\\t\\t\\t\\\"    except Exception as e:\\\",\\n\\t\\t\\t\\\"        clsLogger.ErrorLog(values)\\\",\\n\\t\\t\\t\\\"        clsLogger.ErrorLog(e)\\\"\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"description for Store Procedure Sample\\\"\\n\\t},\\n\\t\\\"Store Procedure Select\\\": {\\n\\t\\t\\\"prefix\\\": \\\"store_procedure\\\",\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"def ${STORE_PROCEDURE}(cursor, home_id):\\\",\\n\\t\\t\\t\\\"\\\",\\n\\t\\t\\t\\\"    query = \\\\\\\"SET NOCOUNT ON; EXEC ${STORE_PROCEDURE} ?;\\\\\\\"\\\",\\n\\t\\t\\t\\\"    values = (home_id)\\\",\\n\\t\\t\\t\\\"\\\",\\n\\t\\t\\t\\\"    try:\\\",\\n\\t\\t\\t\\\"        res_ls = cursor.execute(query, values)\\\",\\n\\t\\t\\t\\\"\\\",\\n\\t\\t\\t\\\"        def f(arr): return { \\\\\\\"device_id\\\\\\\": arr[0], \\\\\\\"device_name\\\\\\\": arr[1], \\\\\\\"sql_id\\\\\\\": arr[2], \\\\\\\"is_temp_humd\\\\\\\": arr[3] }\\\",\\n\\t\\t\\t\\\"        res_ls = [f(obj) for obj in res_ls]\\\",\\n\\t\\t\\t\\\"\\\",\\n\\t\\t\\t\\\"        return res_ls\\\",\\n\\t\\t\\t\\\"    except Exception as ex:\\\",\\n\\t\\t\\t\\\"        clsLogger.ErrorLog(values)\\\",\\n\\t\\t\\t\\\"        clsLogger.ErrorLog(ex)\\\",\\n\\t\\t\\t\\\"\\\",\\n\\t\\t\\t\\\"    return []\\\"\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"description for Store Procedure Select\\\"\\n\\t},\\n\\t\\\"euler\\\": {\\n\\t\\t\\\"prefix\\\": \\\"euler\\\",\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"import time\\\",\\n\\t\\t\\t\\\"\\\",\\n\\t\\t\\t\\\"def main():\\\",\\n\\t\\t\\t\\\"\\\",\\n\\t\\t\\t\\\"    start_time = time.time()\\\",\\n\\t\\t\\t\\\"\\\",\\n\\t\\t\\t\\\"    print(\\\\\\\"Hello, World!\\\\\\\")\\\",\\n\\t\\t\\t\\\"\\\",\\n\\t\\t\\t\\\"    end_time = time.time() - start_time\\\",\\n\\t\\t\\t\\\"    print(f\\\\\\\"Time Taken: {end_time:.2f} seconds\\\\\\\")\\\",\\n\\t\\t\\t\\\"\\\",\\n\\t\\t\\t\\\"if __name__ == \\\\\\\"__main__\\\\\\\":\\\",\\n\\t\\t\\t\\\"    main()\\\"\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"Project Euler\\\"\\n\\t},\\n\\t\\\"Generate Prime List\\\": {\\n\\t\\t\\\"prefix\\\": \\\"prime_ls\\\",\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"def gen_prime_ls(num):\\\",\\n\\t\\t\\t\\\"\\\",\\n\\t\\t\\t\\\"    start = 2\\\",\\n\\t\\t\\t\\\"\\\",\\n\\t\\t\\t\\\"    end = math.sqrt(num)\\\",\\n\\t\\t\\t\\\"    end = int(end)\\\",\\n\\t\\t\\t\\\"\\\",\\n\\t\\t\\t\\\"    flag_ls = [True for _ in range(num)]\\\",\\n\\t\\t\\t\\\"\\\",\\n\\t\\t\\t\\\"    flag_ls[0] = False\\\",\\n\\t\\t\\t\\\"    flag_ls[1] = False\\\",\\n\\t\\t\\t\\\"\\\",\\n\\t\\t\\t\\\"    for ind in range(start, end + 1):\\\",\\n\\t\\t\\t\\\"        if flag_ls[ind]:\\\",\\n\\t\\t\\t\\\"            for jnd in range(ind * ind, num, ind):\\\",\\n\\t\\t\\t\\\"                flag_ls[jnd] = False\\\",\\n\\t\\t\\t\\\"\\\",\\n\\t\\t\\t\\\"    res_ls = []\\\",\\n\\t\\t\\t\\\"\\\",\\n\\t\\t\\t\\\"    for num, flag in enumerate(flag_ls):\\\",\\n\\t\\t\\t\\\"        if flag:\\\",\\n\\t\\t\\t\\\"            res_ls.append(num)\\\",\\n\\t\\t\\t\\\"\\\",\\n\\t\\t\\t\\\"    return res_ls, flag_ls\\\"\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"Generate Prime List\\\"\\n\\t},\\n\\t\\\"Generate Factors of Number\\\": {\\n\\t\\t\\\"prefix\\\": \\\"factors\\\",\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"def gen_factors(n = 10):\\\",\\n\\t\\t\\t\\\"\\\",\\n\\t\\t\\t\\\"    end = int(n // 2) + 1\\\",\\n\\t\\t\\t\\\"\\\",\\n\\t\\t\\t\\\"    res_ls = []\\\",\\n\\t\\t\\t\\\"\\\",\\n\\t\\t\\t\\\"    for num in range(1, end):\\\",\\n\\t\\t\\t\\\"        if n % num == 0:\\\",\\n\\t\\t\\t\\\"            res_ls.append(num)\\\",\\n\\t\\t\\t\\\"\\\",\\n\\t\\t\\t\\\"    return res_ls\\\"\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"Generate Factors of Number\\\"\\n\\t},\\n\\t\\\"main\\\": {\\n\\t\\t\\\"prefix\\\": [\\\"init\\\", \\\"main\\\"],\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"import time\\\",\\n\\t\\t\\t\\\"\\\",\\n\\t\\t\\t\\\"def main():\\\",\\n\\t\\t\\t\\\"    start_time = time.time()\\\",\\n\\t\\t\\t\\\"\\\",\\n\\t\\t\\t\\\"    print(\\\\\\\"Hello, World\\\\\\\")\\\",\\n\\t\\t\\t\\\"\\\",\\n\\t\\t\\t\\\"    end_time = time.time() - start_time\\\",\\n\\t\\t\\t\\\"    print(f\\\\\\\"Time Taken: {end_time:.2f} seconds\\\\\\\")\\\",\\n\\t\\t\\t\\\"\\\",\\n\\t\\t\\t\\\"if __name__ == \\\\\\\"__main__\\\\\\\":\\\",\\n\\t\\t\\t\\\"    main()\\\"\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"main\\\"\\n\\t}\\n}\",\"ruby.json\":\"{\\n\\t\\\"Fastlane Add Commands\\\": {\\n\\t\\t\\\"prefix\\\": \\\"init\\\",\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"    desc \\\\\\\"${1:Description}\\\\\\\"\\\",\\n\\t\\t\\t\\\"    lane :${2:CmdName} do \\\",\\n\\t\\t\\t\\\"        ${3:CmdList}\\\",\\n\\t\\t\\t\\\"    end\\\"\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"description for init\\\"\\n\\t}\\n}\",\"shellscript.json\":\"{\\n\\t// Place your snippets for shellscript here. Each snippet is defined under a snippet name and has a prefix, body and \\n\\t// description. The prefix is what is used to trigger the snippet and the body will be expanded and inserted. Possible variables are:\\n\\t// $1, $2 for tab stops, $0 for the final cursor position, and ${1:label}, ${2:another} for placeholders. Placeholders with the \\n\\t// same ids are connected.\\n\\t// Example:\\n\\t// \\\"Print to console\\\": {\\n\\t// \\t\\\"prefix\\\": \\\"log\\\",\\n\\t// \\t\\\"body\\\": [\\n\\t// \\t\\t\\\"console.log('$1');\\\",\\n\\t// \\t\\t\\\"$2\\\"\\n\\t// \\t],\\n\\t// \\t\\\"description\\\": \\\"Log output to console\\\"\\n\\t// },\\n\\t\\\"Region Comments\\\": {\\n\\t\\t\\\"prefix\\\": \\\"region\\\",\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"#region ${1:region_name}\\\",\\n\\t\\t\\t\\\"$TM_SELECTED_TEXT\\\",\\n\\t\\t\\t\\\"#endregion\\\"\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"description for region\\\"\\n\\t},\\n}\",\"sql.json\":\"{\\n\\t\\\"SQL Insert Statement\\\": {\\n\\t\\t\\\"prefix\\\": \\\"insert\\\",\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"BEGIN TRANSACTION;\\\",\\n\\t\\t\\t\\\"INSERT INTO $1\\\",\\n\\t\\t\\t\\\"(\\\",\\n\\t\\t\\t\\\"$2\\\",\\n\\t\\t\\t\\\")\\\",\\n\\t\\t\\t\\\"VALUES\\\",\\n\\t\\t\\t\\\"(\\\",\\n\\t\\t\\t\\\"$3\\\",\\n\\t\\t\\t\\\");\\\",\\n\\t\\t\\t\\\"COMMIT TRANSACTION;\\\"\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"SQL Insert Statement\\\"\\n\\t},\\n\\t\\\"SQL Update Statment\\\": {\\n\\t\\t\\\"prefix\\\": \\\"update\\\",\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"BEGIN TRANSACTION;\\\",\\n\\t\\t\\t\\\"UPDATE $1\\\",\\n\\t\\t\\t\\\"SET $2\\\",\\n\\t\\t\\t\\\"WHERE 1=1;\\\",\\n\\t\\t\\t\\\"COMMIT TRANSACTION;\\\"\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"SQL Update Statment\\\"\\n\\t},\\n\\t\\\"SQL Delete Statment\\\": {\\n\\t\\t\\\"prefix\\\": \\\"delete\\\",\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"BEGIN TRANSACTION;\\\",\\n\\t\\t\\t\\\"DELETE FROM $1\\\",\\n\\t\\t\\t\\\"WHERE 1=1\\\",\\n\\t\\t\\t\\\"AND $2 = $3;\\\",\\n\\t\\t\\t\\\"COMMIT TRANSACTION;\\\"\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"SQL Delete Statement\\\"\\n\\t},\\n\\t\\\"SQL Select Statment\\\": {\\n\\t\\t\\\"prefix\\\": \\\"select\\\",\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"SELECT * \\\",\\n\\t\\t\\t\\\"FROM $1\\\",\\n\\t\\t\\t\\\"WHERE 1=1;\\\"\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"SQL Select Statment\\\"\\n\\t},\\n\\t\\\"MSSQL: User Credentials Setup\\\": {\\n\\t\\t\\\"prefix\\\": \\\"admin\\\",\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"-- User Table\\\",\\n\\t\\t\\t\\\"DROP TABLE dbo.T${tblName}User;\\\",\\n\\t\\t\\t\\\"\\\",\\n\\t\\t\\t\\\"CREATE TABLE dbo.T${tblName}User(\\\",\\n\\t\\t\\t\\\"\\\\tid INT IDENTITY(1, 1) NOT NULL,\\\",\\n\\t\\t\\t\\\"\\\\tusername VARCHAR(max),\\\",\\n\\t\\t\\t\\\"\\\\tpassword VARCHAR(max),\\\",\\n\\t\\t\\t\\\"\\\\temail_address VARCHAR(max),\\\",\\n\\t\\t\\t\\\"\\\\tCONSTRAINT user_id_pk PRIMARY KEY (id)\\\",\\n\\t\\t\\t\\\");\\\",\\n\\t\\t\\t\\\"\\\",\\n\\t\\t\\t\\\"-- Role Table\\\",\\n\\t\\t\\t\\\"DROP TABLE dbo.T${tblName}Role;\\\",\\n\\t\\t\\t\\\"\\\",\\n\\t\\t\\t\\\"CREATE TABLE dbo.T${tblName}Role(\\\",\\n\\t\\t\\t\\\"\\\\tid INT IDENTITY(1, 1) NOT NULL,\\\",\\n\\t\\t\\t\\\"\\\\tname VARCHAR(100),\\\",\\n\\t\\t\\t\\\"\\\\tCONSTRAINT role_id_pk PRIMARY KEY (id)\\\",\\n\\t\\t\\t\\\");\\\",\\n\\t\\t\\t\\\"\\\",\\n\\t\\t\\t\\\"-- Permission Table\\\",\\n\\t\\t\\t\\\"DROP TABLE dbo.T${tblName}Permission;\\\",\\n\\t\\t\\t\\\"\\\",\\n\\t\\t\\t\\\"CREATE TABLE dbo.T${tblName}Permission(\\\",\\n\\t\\t\\t\\\"\\\\tid INT IDENTITY(1, 1) NOT NULL,\\\",\\n\\t\\t\\t\\\"\\\\tname VARCHAR(100),\\\",\\n\\t\\t\\t\\\"\\\\tlink VARCHAR(100),\\\",\\n\\t\\t\\t\\\"\\\\tCONSTRAINT permission_id_pk PRIMARY KEY (id)\\\",\\n\\t\\t\\t\\\");\\\",\\n\\t\\t\\t\\\"\\\",\\n\\t\\t\\t\\\"-- User Role Table\\\",\\n\\t\\t\\t\\\"DROP TABLE dbo.T${tblName}UserRole;\\\",\\n\\t\\t\\t\\\"\\\",\\n\\t\\t\\t\\\"CREATE TABLE dbo.T${tblName}UserRole(\\\",\\n\\t\\t\\t\\\"\\\\tid INT IDENTITY(1, 1) NOT NULL,\\\",\\n\\t\\t\\t\\\"\\\\tuser_id INT,\\\",\\n\\t\\t\\t\\\"\\\\trole_id INT,\\\",\\n\\t\\t\\t\\\"\\\\tstatus VARCHAR(100), \\\",\\n\\t\\t\\t\\\"\\\\tCONSTRAINT user_role_id_pk PRIMARY KEY (id)\\\",\\n\\t\\t\\t\\\");\\\",\\n\\t\\t\\t\\\"\\\",\\n\\t\\t\\t\\\"-- Role Permission Table\\\",\\n\\t\\t\\t\\\"DROP TABLE dbo.T${tblName}RolePermission;\\\",\\n\\t\\t\\t\\\"\\\",\\n\\t\\t\\t\\\"CREATE TABLE dbo.T${tblName}RolePermission(\\\",\\n\\t\\t\\t\\\"\\\\tid INT IDENTITY(1, 1) NOT NULL,\\\",\\n\\t\\t\\t\\\"\\\\trole_id INT,\\\",\\n\\t\\t\\t\\\"\\\\tpermission_id INT,\\\",\\n\\t\\t\\t\\\"\\\\tstatus VARCHAR(100), \\\",\\n\\t\\t\\t\\\"\\\\tCONSTRAINT role_permission_id_pk PRIMARY KEY (id)\\\",\\n\\t\\t\\t\\\");\\\"\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"SQL Credentials Setup\\\"\\n\\t},\\n\\t\\\"MSSQL: Create SQL Table\\\": {\\n\\t\\t\\\"prefix\\\": \\\"tbl\\\",\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"CREATE TABLE $1(\\\",\\n\\t\\t\\t\\\"    $2 INT IDENTITY(1,1) NOT NULL,\\\",\\n\\t\\t\\t\\\"    CONSTRAINT $1_pk PRIMARY KEY ($2)\\\",\\n\\t\\t\\t\\\");\\\"\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"Initialize SQL Table\\\"\\n\\t},\\n\\t\\\"Postgres: SQL Custom Attribute\\\": {\\n\\t\\t\\\"prefix\\\": \\\"init\\\",\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"Status INT,\\\",\\n\\t\\t\\t\\\"Remark VARCHAR,\\\",\\n\\t\\t\\t\\\"CreatedDate TIMESTAMP,\\\",\\n\\t\\t\\t\\\"LastUpdatedDate TIMESTAMP\\\"\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"SQL Custom Attribute\\\"\\n\\t},\\n\\t\\\"MSSQL: SQL Custom Attribute\\\": {\\n\\t\\t\\\"prefix\\\": \\\"init\\\",\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"Status INT,\\\",\\n\\t\\t\\t\\\"Remark VARCHAR(400),\\\",\\n\\t\\t\\t\\\"CreatedDate DATETIME,\\\",\\n\\t\\t\\t\\\"LastUpdatedDate DATETIME\\\"\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"SQL Custom Attribute\\\"\\n\\t},\\n\\t\\\"MSSQL: Default Values\\\": {\\n\\t\\t\\\"prefix\\\": \\\"init\\\",\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"1, '',\\\",\\n\\t\\t\\t\\\"GETDATE(),\\\",\\n\\t\\t\\t\\\"GETDATE()\\\"\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"MSSQL: Default Values\\\"\\n\\t},\\n\\t\\\"Postgres: Default Values\\\": {\\n\\t\\t\\\"prefix\\\": \\\"init\\\",\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"1, '',\\\",\\n\\t\\t\\t\\\"NOW(),\\\",\\n\\t\\t\\t\\\"NOW()\\\"\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"Postgres: Default Values\\\"\\n\\t},\\n\\t\\\"MSSQL: Store Procedure\\\": {\\n\\t\\t\\\"prefix\\\": \\\"store_procedure\\\",\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"-- EXEC NSP_${1:proc_name}\\\",\\n\\t\\t\\t\\\"CREATE OR ALTER PROCEDURE NSP_${1:proc_name}\\\",\\n\\t\\t\\t\\\"(\\\",\\n\\t\\t\\t\\\")\\\",\\n\\t\\t\\t\\\"AS\\\",\\n\\t\\t\\t\\\"$3\\\",\\n\\t\\t\\t\\\"GO\\\"\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"MSSQL: Store Procedure\\\"\\n\\t},\\n\\t\\\"Case Condition\\\": {\\n\\t\\t\\\"prefix\\\": \\\"case\\\",\\n\\t\\t\\\"body\\\": \\\"AND CASE WHEN ${1:param_id} = -1 THEN ${1:param_id} ELSE ${2:actual_id} END = ${1:param_id} \\\",\\n\\t\\t\\\"description\\\": \\\"description for Case Condition\\\"\\n\\t},\\n\\t\\\"MSSQL: Stored Procedure Source\\\": {\\n\\t\\t\\\"prefix\\\": \\\"sp_helptext\\\",\\n\\t\\t\\\"body\\\": \\\"EXEC sp_helptext $TM_SELECTED_TEXT;\\\",\\n\\t\\t\\\"description\\\": \\\"MSSQL: Stored Procedure Source\\\"\\n\\t},\\n\\t\\\"MSSQL: List All Store Procedure\\\": {\\n\\t\\t\\\"prefix\\\": \\\"store_procedure\\\",\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"SELECT * \\\",\\n\\t\\t\\t\\\"FROM sys.procedures\\\",\\n\\t\\t\\t\\\"WHERE 1=1\\\",\\n\\t\\t\\t\\\"AND name LIKE 'NSP_${1:tableName}%';\\\"\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"MSSQL: List All Store Procedure\\\"\\n\\t},\\n\\t\\\"MSSQL: Execute Stored Procedure\\\": {\\n\\t\\t\\\"prefix\\\": \\\"exec\\\",\\n\\t\\t\\\"body\\\": \\\"EXEC $TM_SELECTED_TEXT\\\",\\n\\t\\t\\\"description\\\": \\\"MSSQL: Execute Stored Procedure\\\"\\n\\t},\\n\\t\\\"MSSQL: Show All Store Procedure\\\": {\\n\\t\\t\\\"prefix\\\": \\\"store_procedure\\\",\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"CREATE TABLE #NewList (\\\",\\n\\t\\t\\t\\\"    name VARCHAR(max),\\\",\\n\\t\\t\\t\\\"    data_type VARCHAR(max)\\\",\\n\\t\\t\\t\\\")\\\",\\n\\t\\t\\t\\\"\\\",\\n\\t\\t\\t\\\"DECLARE @ind INT = 1\\\",\\n\\t\\t\\t\\\"DECLARE @limit INT = (SELECT COUNT(*) FROM sys.procedures)\\\",\\n\\t\\t\\t\\\"DECLARE @proc VARCHAR(max) = ''\\\",\\n\\t\\t\\t\\\"\\\",\\n\\t\\t\\t\\\"WHILE (@ind <= @limit) \\\",\\n\\t\\t\\t\\\"BEGIN\\\",\\n\\t\\t\\t\\\"    SELECT @proc = name\\\",\\n\\t\\t\\t\\\"    FROM sys.procedures\\\",\\n\\t\\t\\t\\\"    ORDER BY name\\\",\\n\\t\\t\\t\\\"    OFFSET (@ind - 1) ROWS\\\",\\n\\t\\t\\t\\\"    FETCH NEXT 1 ROWS ONLY\\\",\\n\\t\\t\\t\\\"\\\",\\n\\t\\t\\t\\\"    INSERT INTO #NewList\\\",\\n\\t\\t\\t\\\"    SELECT @proc, ''\\\",\\n\\t\\t\\t\\\"\\\",\\n\\t\\t\\t\\\"    INSERT INTO #NewList\\\",\\n\\t\\t\\t\\\"    SELECT p.name, t.name\\\",\\n\\t\\t\\t\\\"    FROM sys.parameters p\\\",\\n\\t\\t\\t\\\"    INNER JOIN sys.types t \\\",\\n\\t\\t\\t\\\"    ON p.user_type_id = t.user_type_id\\\",\\n\\t\\t\\t\\\"    INNER JOIN sys.procedures pr \\\",\\n\\t\\t\\t\\\"    ON p.object_id = pr.object_id\\\",\\n\\t\\t\\t\\\"    WHERE 1=1\\\",\\n\\t\\t\\t\\\"    AND pr.name = @proc\\\",\\n\\t\\t\\t\\\"\\\",\\n\\t\\t\\t\\\"    SET @ind = @ind + 1\\\",\\n\\t\\t\\t\\\"END\\\",\\n\\t\\t\\t\\\"\\\",\\n\\t\\t\\t\\\"SELECT * FROM #NewList;\\\"\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"MSSQL: Show All Store Procedure\\\"\\n\\t},\\n\\t\\\"MSSQL: Select Duplicate Records (Device Logs)\\\": {\\n\\t\\t\\\"prefix\\\": \\\"duplicate\\\",\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"DECLARE @startDt DATETIME = '${datetime}'\\\",\\n\\t\\t\\t\\\"DECLARE @endDt DATETIME = '${datetime}'\\\",\\n\\t\\t\\t\\\"\\\",\\n\\t\\t\\t\\\"SELECT *\\\",\\n\\t\\t\\t\\\"FROM TDeviceLogs\\\",\\n\\t\\t\\t\\\"WHERE 1=1\\\",\\n\\t\\t\\t\\\"AND Device_Log_Id IN (\\\",\\n\\t\\t\\t\\\"    SELECT MIN(Device_Log_Id)\\\",\\n\\t\\t\\t\\\"    FROM TDeviceLogs\\\",\\n\\t\\t\\t\\\"    WHERE 1=1\\\",\\n\\t\\t\\t\\\"    AND Record_Date >= @startDt\\\",\\n\\t\\t\\t\\\"    AND Record_Date <= @endDt\\\",\\n\\t\\t\\t\\\"    GROUP BY Device_Id, Record_Date, MetaData\\\",\\n\\t\\t\\t\\\"    HAVING COUNT(*) > 1\\\",\\n\\t\\t\\t\\\");\\\"\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"MSSQL: Select Duplicate Records (Device Logs)\\\"\\n\\t},\\n\\t\\\"MSSQL: Check Database CPU Usage\\\": {\\n\\t\\t\\\"prefix\\\": [\\n\\t\\t\\t\\\"process\\\",\\n\\t\\t\\t\\\"debug\\\",\\n\\t\\t\\t\\\"sql\\\"\\n\\t\\t],\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"WITH CPU_Per_Db AS (\\\",\\n\\t\\t\\t\\\"    SELECT dmpa.DatabaseID,\\\",\\n\\t\\t\\t\\\"        DB_Name(dmpa.DatabaseID) AS [Database],\\\",\\n\\t\\t\\t\\\"        SUM(dmqs.total_worker_time) AS CPUTimeAsMS\\\",\\n\\t\\t\\t\\\"    FROM sys.dm_exec_query_stats dmqs\\\",\\n\\t\\t\\t\\\"        CROSS APPLY (\\\",\\n\\t\\t\\t\\\"            SELECT CONVERT(INT, value) AS [DatabaseID]\\\",\\n\\t\\t\\t\\\"            FROM sys.dm_exec_plan_attributes(dmqs.plan_handle)\\\",\\n\\t\\t\\t\\\"            WHERE attribute = N'dbid'\\\",\\n\\t\\t\\t\\\"        ) dmpa\\\",\\n\\t\\t\\t\\\"    GROUP BY dmpa.DatabaseID\\\",\\n\\t\\t\\t\\\")\\\",\\n\\t\\t\\t\\\"SELECT [Database],\\\",\\n\\t\\t\\t\\\"    [CPUTimeAsMS],\\\",\\n\\t\\t\\t\\\"    CAST(\\\",\\n\\t\\t\\t\\\"        [CPUTimeAsMS] * 1.0 / SUM([CPUTimeAsMS]) OVER() * 100.0 AS DECIMAL(5, 2)\\\",\\n\\t\\t\\t\\\"    ) AS [CPUTimeAs{96f5cbaad583fb885ff5d18ecce5734bf1e8596949521e20c290401929518f75}]\\\",\\n\\t\\t\\t\\\"FROM CPU_Per_Db\\\",\\n\\t\\t\\t\\\"ORDER BY [CPUTimeAsMS] DESC;\\\"\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"MSSQL: Check Database CPU Usage\\\"\\n\\t},\\n\\t\\\"MSSQL: Check Query Process\\\": {\\n\\t\\t\\\"prefix\\\": [\\n\\t\\t\\t\\\"process\\\",\\n\\t\\t\\t\\\"debug\\\",\\n\\t\\t\\t\\\"sql\\\"\\n\\t\\t],\\n\\t\\t\\\"body\\\": \\\"SELECT * FROM sys.dm_exec_sessions WHERE status = 'running';\\\",\\n\\t\\t\\\"description\\\": \\\"MSSQL: Check Query Process\\\"\\n\\t},\\n\\t\\\"MSSQL: SQL Info\\\": {\\n\\t\\t\\\"prefix\\\": \\\"info\\\",\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"SELECT *\\\",\\n\\t\\t\\t\\\"FROM information_schema.columns\\\",\\n\\t\\t\\t\\\"WHERE 1=1;\\\"\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"MSSQL: SQL Info\\\"\\n\\t},\\n\\t\\\"MSSQL: Generate CSV Header\\\": {\\n\\t\\t\\\"prefix\\\": [\\n\\t\\t\\t\\\"csv\\\",\\n\\t\\t\\t\\\"info\\\"\\n\\t\\t],\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"-- Generate Headers\\\",\\n\\t\\t\\t\\\"DECLARE @colname VARCHAR(max)\\\",\\n\\t\\t\\t\\\"DECLARE @tblname VARCHAR(max) = '${1:tbl_name}'\\\",\\n\\t\\t\\t\\\"SELECT @colname = COALESCE(@colname + ',', '') + [COLUMN_NAME]\\\",\\n\\t\\t\\t\\\"FROM information_schema.columns\\\",\\n\\t\\t\\t\\\"WHERE 1=1\\\",\\n\\t\\t\\t\\\"AND [TABLE_NAME] = @tblname\\\",\\n\\t\\t\\t\\\"SELECT @colname;\\\"\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"description for SQL Headers\\\"\\n\\t},\\n\\t\\\"MSSQL: Sample Table\\\": {\\n\\t\\t\\\"prefix\\\": \\\"sample_tbl\\\",\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"CREATE TABLE TSample(\\\",\\n\\t\\t\\t\\\"    SampleId INT IDENTITY(1,1) NOT NULL,\\\",\\n\\t\\t\\t\\\"    Title VARCHAR,\\\",\\n\\t\\t\\t\\\"    Description NVARCHAR(max),\\\",\\n\\t\\t\\t\\\"    Price DECIMAL(10, 6),\\\",\\n\\t\\t\\t\\\"    Quantity INT,\\\",\\n\\t\\t\\t\\\"    CreatedBy NVARCHAR(max),\\\",\\n\\t\\t\\t\\\"    CreatedAt DATETIME,\\\",\\n\\t\\t\\t\\\"    CONSTRAINT TSample_pk PRIMARY KEY (SampleId)\\\",\\n\\t\\t\\t\\\");\\\"\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"MSSQL: Sample Table\\\"\\n\\t},\\n\\t\\\"Postgres: Sample Table\\\": {\\n\\t\\t\\\"prefix\\\": \\\"sample_tbl\\\",\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"CREATE TABLE TSample (\\\",\\n\\t\\t\\t\\\"    SampleId INT PRIMARY KEY GENERATED ALWAYS AS IDENTITY,\\\",\\n\\t\\t\\t\\\"    Title VARCHAR,\\\",\\n\\t\\t\\t\\\"    Description VARCHAR,\\\",\\n\\t\\t\\t\\\"    Price DECIMAL(10, 6),\\\",\\n\\t\\t\\t\\\"    Quantity INT,\\\",\\n\\t\\t\\t\\\"    CreatedBy VARCHAR,\\\",\\n\\t\\t\\t\\\"    CreatedAt TIMESTAMP\\\",\\n\\t\\t\\t\\\");\\\"\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"Postgres: Sample Table\\\"\\n\\t},\\n\\t\\\"Postgres: Create Table\\\": {\\n\\t\\t\\\"prefix\\\": \\\"tbl\\\",\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"CREATE TABLE ${tblName} (\\\",\\n\\t\\t\\t\\\"    ${Id} INT PRIMARY KEY,\\\",\\n\\t\\t\\t\\\");\\\"\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"Postgres: SQL\\\"\\n\\t},\\n\\t\\\"Postgres: Select Insert Temp\\\": {\\n\\t\\t\\\"prefix\\\": \\\"temp\\\",\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"CREATE TEMP TABLE ${tmp_tbl_name} AS\\\",\\n\\t\\t\\t\\\"SELECT * FROM ${table_name}\\\"\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"Postgres: Select Insert Temp\\\"\\n\\t},\\n\\t\\\"Postgres: Stored Procedure\\\": {\\n\\t\\t\\\"prefix\\\": \\\"store_procedure\\\",\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"CREATE OR REPLACE PROCEDURE ${1:procedure_name}(\\\",\\n\\t\\t\\t\\\")\\\",\\n\\t\\t\\t\\\"AS $$\\\",\\n\\t\\t\\t\\\"BEGIN\\\",\\n\\t\\t\\t\\\"-- CALL ${1:procedure_name}();\\\",\\n\\t\\t\\t\\\"END;\\\",\\n\\t\\t\\t\\\"$$ LANGUAGE plpgsql;\\\"\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"Postgres: Store Procedure\\\"\\n\\t},\\n\\t\\\"Commit Transaction\\\": {\\n\\t\\t\\\"prefix\\\": \\\"commit\\\",\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"COMMIT TRANSACTION;\\\"\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"Commit Transaction\\\"\\n\\t},\\n\\t\\\"Rollback Transaction\\\": {\\n\\t\\t\\\"prefix\\\": \\\"rollback\\\",\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"ROLLBACK;\\\"\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"Rollback Transaction\\\"\\n\\t},\\n\\t\\\"Postgres: Temp Function\\\": {\\n\\t\\t\\\"prefix\\\": \\\"function\\\",\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"DO \\\\\\\\$func$\\\",\\n\\t\\t\\t\\\"DECLARE \\\",\\n\\t\\t\\t\\\"BEGIN \\\",\\n\\t\\t\\t\\\"END;\\\",\\n\\t\\t\\t\\\"\\\\\\\\$func$ LANGUAGE plpgsql;\\\"\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"Postgres: Temp Function\\\"\\n\\t},\\n\\t\\\"Postgres: Create View\\\": {\\n\\t\\t\\\"prefix\\\": \\\"view\\\",\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"CREATE OR REPLACE VIEW ${view_name}\\\",\\n\\t\\t\\t\\\"AS\\\",\\n\\t\\t\\t\\\"SELECT * \\\",\\n\\t\\t\\t\\\"FROM ${table_name}\\\",\\n\\t\\t\\t\\\"WHERE 1=1;\\\"\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"Postgres: Create View\\\"\\n\\t},\\n\\t\\\"Postgres: Variables\\\": {\\n\\t\\t\\\"prefix\\\": \\\"variables\\\",\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"WITH ${var_obj} AS (\\\",\\n\\t\\t\\t\\\"    SELECT '2000-08-18'::DATE AS startDT,\\\",\\n\\t\\t\\t\\\"    NOW()::DATE AS endDt\\\",\\n\\t\\t\\t\\\")\\\",\\n\\t\\t\\t\\\"SELECT *\\\",\\n\\t\\t\\t\\\"FROM ${var_obj}\\\",\\n\\t\\t\\t\\\"WHERE 1=1\\\"\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"Postgres: Variables\\\"\\n\\t},\\n\\t\\\"Postgres: Function\\\": {\\n\\t\\t\\\"prefix\\\": \\\"function\\\",\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"CREATE OR REPLACE FUNCTION ${proc_name}()\\\",\\n\\t\\t\\t\\\"RETURNS ${VOID}\\\",\\n\\t\\t\\t\\\"AS \\\\\\\\$func$\\\",\\n\\t\\t\\t\\\"BEGIN\\\",\\n\\t\\t\\t\\\"    RETURN ${data_type_ii}\\\",\\n\\t\\t\\t\\\"    -- SELECT ${proc_name}();\\\",\\n\\t\\t\\t\\\"END;\\\",\\n\\t\\t\\t\\\"\\\\\\\\$func$ LANGUAGE plpgsql;\\\"\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"Postgres: Function\\\"\\n\\t},\\n\\t\\\"Postgres: List all Tables\\\": {\\n\\t\\t\\\"prefix\\\": \\\"tbl\\\",\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"SELECT tablename FROM pg_catalog.pg_tables WHERE schemaname = 'public';\\\"\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"Postgres: List All Tables\\\"\\n\\t},\\n\\t\\\"Postgres: Get Table Info \\\": {\\n\\t\\t\\\"prefix\\\": \\\"tblInfo\\\",\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"SELECT column_name, data_type, character_maximum_length \\\",\\n\\t\\t\\t\\\"FROM information_schema.columns \\\",\\n\\t\\t\\t\\\"WHERE table_name = '${tblName}';\\\"\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"Postgres: Get Table Info\\\"\\n\\t},\\n\\t\\\"Postgres: Check Dependency\\\": {\\n\\t\\t\\\"prefix\\\": \\\"depend\\\",\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"CREATE OR REPLACE VIEW admin.v_view_dependency AS \\\",\\n\\t\\t\\t\\\"    SELECT DISTINCT srcobj.oid AS src_oid\\\",\\n\\t\\t\\t\\\"    , srcnsp.nspname AS src_schemaname\\\",\\n\\t\\t\\t\\\"    , srcobj.relname AS src_objectname\\\",\\n\\t\\t\\t\\\"    , tgtobj.oid AS dependent_viewoid\\\",\\n\\t\\t\\t\\\"    , tgtnsp.nspname AS dependant_schemaname\\\",\\n\\t\\t\\t\\\"    , tgtobj.relname AS dependant_objectname\\\",\\n\\t\\t\\t\\\"    FROM pg_class srcobj\\\",\\n\\t\\t\\t\\\"    JOIN pg_depend srcdep ON srcobj.oid = srcdep.refobjid\\\",\\n\\t\\t\\t\\\"    JOIN pg_depend tgtdep ON srcdep.objid = tgtdep.objid\\\",\\n\\t\\t\\t\\\"    JOIN pg_class tgtobj ON tgtdep.refobjid = tgtobj.oid AND srcobj.oid <> tgtobj.oid\\\",\\n\\t\\t\\t\\\"    LEFT JOIN pg_namespace srcnsp ON srcobj.relnamespace = srcnsp.oid\\\",\\n\\t\\t\\t\\\"    LEFT JOIN pg_namespace tgtnsp ON tgtobj.relnamespace = tgtnsp.oid\\\",\\n\\t\\t\\t\\\"    WHERE tgtdep.deptype = 'i'::\\\\\\\"char\\\\\\\" AND tgtobj.relkind = 'v'::\\\\\\\"char\\\\\\\";\\\"\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"Postgres: Check Table Dependency\\\"\\n\\t},\\n\\t\\\"Postgres: List all Functions\\\": {\\n\\t\\t\\\"prefix\\\": \\\"function\\\",\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"SELECT \\\",\\n\\t\\t\\t\\\"    n.nspname AS schema_name, p.proname AS function_name\\\",\\n\\t\\t\\t\\\"FROM pg_proc p\\\",\\n\\t\\t\\t\\\"JOIN pg_namespace n ON p.pronamespace = n.oid\\\",\\n\\t\\t\\t\\\"WHERE n.nspname NOT IN ('pg_catalog', 'information_schema');\\\"\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"Postgres: List all Functions\\\"\\n\\t},\\n\\t\\\"Postgres: Function Source Code\\\": {\\n\\t\\t\\\"prefix\\\": \\\"helptext\\\",\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"SELECT pg_get_functiondef(p.oid) AS function_definition\\\",\\n\\t\\t\\t\\\"FROM pg_proc p\\\",\\n\\t\\t\\t\\\"JOIN pg_namespace n ON p.pronamespace = n.oid\\\",\\n\\t\\t\\t\\\"WHERE n.nspname = 'public'\\\",\\n\\t\\t\\t\\\"AND p.proname LIKE '${function_name}';\\\"\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"Postgres: Function Source Code\\\"\\n\\t},\\n\\t\\\"Postgres: Sample Temp Function\\\": {\\n\\t\\t\\\"prefix\\\": [\\n\\t\\t\\t\\\"function\\\",\\n\\t\\t\\t\\\"temp\\\",\\n\\t\\t\\t\\\"delete_all_function\\\"\\n\\t\\t],\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"DO $$ \\\",\\n\\t\\t\\t\\\"DECLARE\\\",\\n\\t\\t\\t\\\"    r RECORD;\\\",\\n\\t\\t\\t\\\"BEGIN\\\",\\n\\t\\t\\t\\\"    -- Loop through all user-defined functions in the 'public' schema (change schema if needed)\\\",\\n\\t\\t\\t\\\"    FOR r IN \\\",\\n\\t\\t\\t\\\"        SELECT n.nspname AS schema_name, \\\",\\n\\t\\t\\t\\\"               p.proname AS function_name, \\\",\\n\\t\\t\\t\\\"               pg_catalog.pg_get_function_identity_arguments(p.oid) AS args\\\",\\n\\t\\t\\t\\\"        FROM pg_proc p\\\",\\n\\t\\t\\t\\\"        JOIN pg_namespace n ON p.pronamespace = n.oid\\\",\\n\\t\\t\\t\\\"        WHERE n.nspname = 'public'  -- Specify your schema here, 'public' by default\\\",\\n\\t\\t\\t\\\"        AND n.nspname NOT IN ('pg_catalog', 'information_schema')  -- Exclude system schemas\\\",\\n\\t\\t\\t\\\"    LOOP\\\",\\n\\t\\t\\t\\\"        -- Execute drop statement for each function\\\",\\n\\t\\t\\t\\\"        EXECUTE 'DROP FUNCTION IF EXISTS ' || r.schema_name || '.' || r.function_name || '(' || r.args || ') CASCADE';\\\",\\n\\t\\t\\t\\\"    END LOOP;\\\",\\n\\t\\t\\t\\\"END $$;\\\"\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"Postgres: Sample Temp Function\\\"\\n\\t},\\n\\t\\\"Postgres: Sample Table with Function\\\": {\\n\\t\\t\\\"prefix\\\": \\\"sample_tbl\\\",\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"CREATE TABLE TSample (\\\",\\n\\t\\t\\t\\\"    SampleId INT PRIMARY KEY GENERATED ALWAYS AS IDENTITY,\\\",\\n\\t\\t\\t\\\"    Title VARCHAR,\\\",\\n\\t\\t\\t\\\"    Description VARCHAR,\\\",\\n\\t\\t\\t\\\"    Price DECIMAL(10,6),\\\",\\n\\t\\t\\t\\\"    Quantity INT,\\\",\\n\\t\\t\\t\\\"    CreatedBy VARCHAR,\\\",\\n\\t\\t\\t\\\"    CreatedAt TIMESTAMP\\\",\\n\\t\\t\\t\\\");\\\",\\n\\t\\t\\t\\\"\\\",\\n\\t\\t\\t\\\"-- Stored Procedure: Select All Record\\\",\\n\\t\\t\\t\\\"CREATE OR REPLACE FUNCTION NSP_TSample_SelectAll(\\\",\\n\\t\\t\\t\\\"    p_SampleId INT DEFAULT -1\\\",\\n\\t\\t\\t\\\")\\\",\\n\\t\\t\\t\\\"RETURNS TABLE (\\\",\\n\\t\\t\\t\\\"    t_SampleId INT,\\\",\\n\\t\\t\\t\\\"    t_Title VARCHAR,\\\",\\n\\t\\t\\t\\\"    t_Description VARCHAR,\\\",\\n\\t\\t\\t\\\"    t_Price DECIMAL(10,6),\\\",\\n\\t\\t\\t\\\"    t_Quantity INT,\\\",\\n\\t\\t\\t\\\"    t_CreatedBy VARCHAR,\\\",\\n\\t\\t\\t\\\"    t_CreatedAt TIMESTAMP\\\",\\n\\t\\t\\t\\\") \\\",\\n\\t\\t\\t\\\"AS \\\\\\\\$func$\\\",\\n\\t\\t\\t\\\"BEGIN\\\",\\n\\t\\t\\t\\\"    RETURN QUERY\\\",\\n\\t\\t\\t\\\"    SELECT * \\\",\\n\\t\\t\\t\\\"    FROM TSample \\\",\\n\\t\\t\\t\\\"    WHERE 1=1\\\",\\n\\t\\t\\t\\\"    AND CASE WHEN p_SampleId = -1 THEN p_SampleId ELSE SampleId END = p_SampleId \\\",\\n\\t\\t\\t\\\"    ORDER BY SampleId;\\\",\\n\\t\\t\\t\\\"    -- SELECT * FROM NSP_TSample_SelectAll();\\\",\\n\\t\\t\\t\\\"END;\\\",\\n\\t\\t\\t\\\"\\\\\\\\$func$ LANGUAGE plpgsql;\\\",\\n\\t\\t\\t\\\"\\\",\\n\\t\\t\\t\\\"-- Stored Procedure: Select By Primary Key\\\",\\n\\t\\t\\t\\\"CREATE OR REPLACE FUNCTION NSP_TSample_SelectByPk(\\\",\\n\\t\\t\\t\\\"    p_SampleId INT DEFAULT -1\\\",\\n\\t\\t\\t\\\")\\\",\\n\\t\\t\\t\\\"RETURNS TABLE (\\\",\\n\\t\\t\\t\\\"    t_SampleId INT,\\\",\\n\\t\\t\\t\\\"    t_Title VARCHAR,\\\",\\n\\t\\t\\t\\\"    t_Description VARCHAR,\\\",\\n\\t\\t\\t\\\"    t_Price DECIMAL(10,6),\\\",\\n\\t\\t\\t\\\"    t_Quantity INT,\\\",\\n\\t\\t\\t\\\"    t_CreatedBy VARCHAR,\\\",\\n\\t\\t\\t\\\"    t_CreatedAt TIMESTAMP\\\",\\n\\t\\t\\t\\\") \\\",\\n\\t\\t\\t\\\"AS \\\\\\\\$func$\\\",\\n\\t\\t\\t\\\"BEGIN\\\",\\n\\t\\t\\t\\\"    RETURN QUERY\\\",\\n\\t\\t\\t\\\"    SELECT * \\\",\\n\\t\\t\\t\\\"    FROM TSample \\\",\\n\\t\\t\\t\\\"    WHERE SampleId = p_SampleId;\\\",\\n\\t\\t\\t\\\"    -- SELECT * FROM NSP_TSample_SelectByPk();\\\",\\n\\t\\t\\t\\\"END;\\\",\\n\\t\\t\\t\\\"\\\\\\\\$func$ LANGUAGE plpgsql;\\\",\\n\\t\\t\\t\\\"\\\",\\n\\t\\t\\t\\\"-- Stored Procedure: Select For DropDown\\\",\\n\\t\\t\\t\\\"CREATE OR REPLACE FUNCTION NSP_TSample_SelectDropDown(\\\",\\n\\t\\t\\t\\\"    p_SampleId INT,\\\",\\n\\t\\t\\t\\\"    p_SelectedAll INT DEFAULT 0\\\",\\n\\t\\t\\t\\\")\\\",\\n\\t\\t\\t\\\"RETURNS TABLE (\\\",\\n\\t\\t\\t\\\"    t_ValueField INT,\\\",\\n\\t\\t\\t\\\"    t_TextField VARCHAR\\\",\\n\\t\\t\\t\\\")\\\",\\n\\t\\t\\t\\\"AS \\\\\\\\$func$\\\",\\n\\t\\t\\t\\\"BEGIN\\\",\\n\\t\\t\\t\\\"    CREATE TEMP TABLE NewList (\\\",\\n\\t\\t\\t\\\"        ValueField INT,\\\",\\n\\t\\t\\t\\\"        TextField VARCHAR\\\",\\n\\t\\t\\t\\\"    ) ON COMMIT DROP;\\\",\\n\\t\\t\\t\\\"\\\",\\n\\t\\t\\t\\\"    IF p_SelectedAll = -1 THEN\\\",\\n\\t\\t\\t\\\"        INSERT INTO NewList(ValueField, TextField)\\\",\\n\\t\\t\\t\\\"        VALUES (-1, 'Selected All');\\\",\\n\\t\\t\\t\\\"    END IF;\\\",\\n\\t\\t\\t\\\"\\\",\\n\\t\\t\\t\\\"    INSERT INTO NewList\\\",\\n\\t\\t\\t\\\"    SELECT SampleId, Title\\\",\\n\\t\\t\\t\\\"    FROM TSample\\\",\\n\\t\\t\\t\\\"    WHERE 1=1\\\",\\n\\t\\t\\t\\\"    AND CASE WHEN p_SampleId = -1 THEN p_SampleId ELSE SampleId END = p_SampleId \\\",\\n\\t\\t\\t\\\"    ORDER BY Title;\\\",\\n\\t\\t\\t\\\"\\\",\\n\\t\\t\\t\\\"    RETURN QUERY\\\",\\n\\t\\t\\t\\\"    SELECT * \\\",\\n\\t\\t\\t\\\"    FROM NewList\\\",\\n\\t\\t\\t\\\"    WHERE 1=1;\\\",\\n\\t\\t\\t\\\"    -- SELECT * FROM NSP_TSample_SelectDropDown();\\\",\\n\\t\\t\\t\\\"END;\\\",\\n\\t\\t\\t\\\"\\\\\\\\$func$ LANGUAGE plpgsql;\\\",\\n\\t\\t\\t\\\"\\\",\\n\\t\\t\\t\\\"-- Stored Procedure: Insert New Record\\\",\\n\\t\\t\\t\\\"CREATE OR REPLACE FUNCTION NSP_TSample_Insert(\\\",\\n\\t\\t\\t\\\"    p_Title VARCHAR,\\\",\\n\\t\\t\\t\\\"    p_Description VARCHAR,\\\",\\n\\t\\t\\t\\\"    p_Price DECIMAL(10,6),\\\",\\n\\t\\t\\t\\\"    p_Quantity INT,\\\",\\n\\t\\t\\t\\\"    p_CreatedBy VARCHAR,\\\",\\n\\t\\t\\t\\\"    p_CreatedAt TIMESTAMP\\\",\\n\\t\\t\\t\\\")\\\",\\n\\t\\t\\t\\\"RETURNS VOID\\\",\\n\\t\\t\\t\\\"AS \\\\\\\\$func$\\\",\\n\\t\\t\\t\\\"BEGIN\\\",\\n\\t\\t\\t\\\"    INSERT INTO TSample (\\\",\\n\\t\\t\\t\\\"        Title,\\\",\\n\\t\\t\\t\\\"        Description,\\\",\\n\\t\\t\\t\\\"        Price,\\\",\\n\\t\\t\\t\\\"        Quantity,\\\",\\n\\t\\t\\t\\\"        CreatedBy,\\\",\\n\\t\\t\\t\\\"        CreatedAt\\\",\\n\\t\\t\\t\\\"    )\\\",\\n\\t\\t\\t\\\"    VALUES (\\\",\\n\\t\\t\\t\\\"        p_Title,\\\",\\n\\t\\t\\t\\\"        p_Description,\\\",\\n\\t\\t\\t\\\"        p_Price,\\\",\\n\\t\\t\\t\\\"        p_Quantity,\\\",\\n\\t\\t\\t\\\"        p_CreatedBy,\\\",\\n\\t\\t\\t\\\"        p_CreatedAt\\\",\\n\\t\\t\\t\\\"    );\\\",\\n\\t\\t\\t\\\"    -- SELECT NSP_TSample_Insert();\\\",\\n\\t\\t\\t\\\"END;\\\",\\n\\t\\t\\t\\\"\\\\\\\\$func$ LANGUAGE plpgsql;\\\",\\n\\t\\t\\t\\\"\\\",\\n\\t\\t\\t\\\"-- Stored Procedure: Update Existing Record\\\",\\n\\t\\t\\t\\\"CREATE OR REPLACE FUNCTION NSP_TSample_Update(\\\",\\n\\t\\t\\t\\\"    p_SampleId INT,\\\",\\n\\t\\t\\t\\\"    p_Title VARCHAR,\\\",\\n\\t\\t\\t\\\"    p_Description VARCHAR,\\\",\\n\\t\\t\\t\\\"    p_Price DECIMAL(10,6),\\\",\\n\\t\\t\\t\\\"    p_Quantity INT,\\\",\\n\\t\\t\\t\\\"    p_CreatedBy VARCHAR,\\\",\\n\\t\\t\\t\\\"    p_CreatedAt TIMESTAMP\\\",\\n\\t\\t\\t\\\")\\\",\\n\\t\\t\\t\\\"RETURNS VOID\\\",\\n\\t\\t\\t\\\"AS \\\\\\\\$func$\\\",\\n\\t\\t\\t\\\"BEGIN\\\",\\n\\t\\t\\t\\\"    UPDATE TSample\\\",\\n\\t\\t\\t\\\"    SET \\\",\\n\\t\\t\\t\\\"        Title = p_Title,\\\",\\n\\t\\t\\t\\\"        Description = p_Description,\\\",\\n\\t\\t\\t\\\"        Price = p_Price,\\\",\\n\\t\\t\\t\\\"        Quantity = p_Quantity,\\\",\\n\\t\\t\\t\\\"        CreatedBy = p_CreatedBy,\\\",\\n\\t\\t\\t\\\"        CreatedAt = p_CreatedAt\\\",\\n\\t\\t\\t\\\"    WHERE 1=1\\\",\\n\\t\\t\\t\\\"    AND SampleId = p_SampleId;\\\",\\n\\t\\t\\t\\\"    -- SELECT NSP_TSample_Update();\\\",\\n\\t\\t\\t\\\"END;\\\",\\n\\t\\t\\t\\\"\\\\\\\\$func$ LANGUAGE plpgsql;\\\",\\n\\t\\t\\t\\\"\\\",\\n\\t\\t\\t\\\"-- Stored Procedure: Delete Existing Record\\\",\\n\\t\\t\\t\\\"CREATE OR REPLACE FUNCTION NSP_TSample_Delete(\\\",\\n\\t\\t\\t\\\"    p_SampleId INT\\\",\\n\\t\\t\\t\\\")\\\",\\n\\t\\t\\t\\\"RETURNS VOID\\\",\\n\\t\\t\\t\\\"AS \\\\\\\\$func$\\\",\\n\\t\\t\\t\\\"BEGIN\\\",\\n\\t\\t\\t\\\"    DELETE FROM TSample\\\",\\n\\t\\t\\t\\\"    WHERE 1=1\\\",\\n\\t\\t\\t\\\"    AND SampleId = p_SampleId;\\\",\\n\\t\\t\\t\\\"    -- SELECT NSP_TSample_Delete();\\\",\\n\\t\\t\\t\\\"END;\\\",\\n\\t\\t\\t\\\"\\\\\\\\$func$ LANGUAGE plpgsql;\\\",\\n\\t\\t\\t\\\"\\\",\\n\\t\\t\\t\\\"SELECT NSP_TSample_Insert('John Ballard', 'Excepteur eiusmod duis deserunt sit minim enim excepteur.', 69, 201, 'Admin', NOW()::TIMESTAMP);\\\",\\n\\t\\t\\t\\\"SELECT NSP_TSample_Insert('Connor Bowers', 'Non enim sit ex fugiat velit in dolor.', 47, 967, 'Admin', NOW()::TIMESTAMP);\\\",\\n\\t\\t\\t\\\"SELECT NSP_TSample_Insert('Connor Bowers', 'Non enim sit ex fugiat velit in dolor.', 47, 967, 'Admin', NOW()::TIMESTAMP);\\\",\\n\\t\\t\\t\\\"SELECT NSP_TSample_Insert('Joshua Green', 'Sit incididunt reprehenderit anim irure est incididunt quis ipsum elit et minim dolor.', 51, 509, 'Admin', NOW()::TIMESTAMP);\\\",\\n\\t\\t\\t\\\"SELECT NSP_TSample_Insert('Ricky James', 'Ut occaecat sit deserunt minim nulla exercitation.', 43, 74, 'Admin', NOW()::TIMESTAMP);\\\"\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"Postgres: Sample Table with Function\\\"\\n\\t}\\n}\",\"terraform.json\":\"{\\n\\t\\\"Starter\\\": {\\n\\t\\t\\\"prefix\\\": \\\"init\\\",\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"terraform {\\\",\\n\\t\\t\\t\\\"  required_providers {\\\",\\n\\t\\t\\t\\\"    $provider_name = {\\\",\\n\\t\\t\\t\\\"      source = \\\\\\\"kreuzwerker/$provider_name\\\\\\\"\\\",\\n\\t\\t\\t\\\"    }\\\",\\n\\t\\t\\t\\\"  }\\\",\\n\\t\\t\\t\\\"}\\\",\\n\\t\\t\\t\\\"\\\",\\n\\t\\t\\t\\\"provider \\\\\\\"$provider_name\\\\\\\" {}\\\"\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"Basic Configuration for Terraform\\\"\\n\\t},\\n\\t\\\"Initialize Azure Provider\\\": {\\n\\t\\t\\\"prefix\\\": \\\"init_azure\\\",\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"terraform {\\\",\\n\\