ger.error(obj);\\\",\\n\\t\\t\\t\\\"        return next(new AppError(obj.message, obj.statusCode, obj.error));\\\",\\n\\t\\t\\t\\\"    }\\\",\\n\\t\\t\\t\\\"\\\",\\n\\t\\t\\t\\\"    const respMsg = \\\\\\\"Success!\\\\\\\";\\\",\\n\\t\\t\\t\\\"    clsLogger.info(genRespObj(STATUS_CODES.OK, respMsg, resData));\\\",\\n\\t\\t\\t\\\"\\\",\\n\\t\\t\\t\\\"    return sendResponse(res, STATUS_CODES.OK, respMsg, resData);\\\",\\n\\t\\t\\t\\\"}\\\"\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"Express Controller: Function\\\"\\n\\t},\\n\\t\\\"React API: fetch Template\\\": {\\n\\t\\t\\\"prefix\\\": \\\"fetch\\\",\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"import { clsUtility } from \\\\\\\"@utility\\\\\\\";\\\",\\n\\t\\t\\t\\\"import { clsConst } from \\\\\\\"@config\\\\\\\";\\\",\\n\\t\\t\\t\\\"\\\",\\n\\t\\t\\t\\\"const { APP_NAME } = clsConst;\\\",\\n\\t\\t\\t\\\"\\\",\\n\\t\\t\\t\\\"const Index = async (param) => {\\\",\\n\\t\\t\\t\\\"\\\",\\n\\t\\t\\t\\\"    try {\\\",\\n\\t\\t\\t\\\"        const action = \\\\\\\"${action_name}\\\\\\\";\\\",\\n\\t\\t\\t\\\"        const url = clsUtility.genServerUrl(action);\\\",\\n\\t\\t\\t\\\"\\\",\\n\\t\\t\\t\\\"        // Static Data\\\",\\n\\t\\t\\t\\\"        let obj = clsUtility.requestObj(param);\\\",\\n\\t\\t\\t\\\"\\\",\\n\\t\\t\\t\\\"        const resp = await fetch(url, {\\\",\\n\\t\\t\\t\\\"            method: \\\\\\\"POST\\\\\\\",\\\",\\n\\t\\t\\t\\\"            headers: {\\\",\\n\\t\\t\\t\\\"                \\\\\\\"Content-Type\\\\\\\": \\\\\\\"application/json\\\\\\\",\\\",\\n\\t\\t\\t\\\"            },\\\",\\n\\t\\t\\t\\\"            body: JSON.stringify(obj),\\\",\\n\\t\\t\\t\\\"        });\\\",\\n\\t\\t\\t\\\"\\\",\\n\\t\\t\\t\\\"        const data = await resp.json();\\\",\\n\\t\\t\\t\\\"\\\",\\n\\t\\t\\t\\\"        console.log(`\\\\\\\\${APP_NAME} - \\\\\\\\${action} - Request - \\\\\\\\${JSON.stringify(obj)}`);\\\",\\n\\t\\t\\t\\\"        console.log(`\\\\\\\\${APP_NAME} - \\\\\\\\${action} - Response - \\\\\\\\${JSON.stringify(data)}`);\\\",\\n\\t\\t\\t\\\"\\\",\\n\\t\\t\\t\\\"        return data;\\\",\\n\\t\\t\\t\\\"    } catch (error) {\\\",\\n\\t\\t\\t\\\"        throw error;\\\",\\n\\t\\t\\t\\\"    }\\\",\\n\\t\\t\\t\\\"\\\",\\n\\t\\t\\t\\\"    return null;\\\",\\n\\t\\t\\t\\\"};\\\",\\n\\t\\t\\t\\\"\\\",\\n\\t\\t\\t\\\"export default Index;\\\"\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"React API: fetch Template\\\"\\n\\t},\\n\\t\\\"React: Sample Empty\\\": {\\n\\t\\t\\\"prefix\\\": [\\\"main\\\", \\\"init\\\"],\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"import React, { useState, useEffect } from \\\\\\\"react\\\\\\\";\\\",\\n\\t\\t\\t\\\"\\\",\\n\\t\\t\\t\\\"function Index(props) {\\\",\\n\\t\\t\\t\\\"    return (\\\",\\n\\t\\t\\t\\\"        <div>\\\",\\n\\t\\t\\t\\\"            <h1>This is Empty Page</h1>\\\",\\n\\t\\t\\t\\\"        </div>\\\",\\n\\t\\t\\t\\\"    )\\\",\\n\\t\\t\\t\\\"}\\\",\\n\\t\\t\\t\\\"\\\",\\n\\t\\t\\t\\\"export default Index;\\\"\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"React: Sample Empty\\\"\\n\\t},\\n\\t\\\"React API: Axios\\\": {\\n\\t\\t\\\"prefix\\\": \\\"axios\\\",\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"import { axiosRequest, genLogUrl, genServerUrl, requestObj } from \\\\\\\"@libs/api/Axios\\\\\\\";\\\",\\n\\t\\t\\t\\\"\\\",\\n\\t\\t\\t\\\"const Index = async (param = {}) => {\\\",\\n\\t\\t\\t\\\"\\\",\\n\\t\\t\\t\\\"    const action = \\\\\\\"${1:API URL}\\\\\\\";\\\",\\n\\t\\t\\t\\\"    const url = genServerUrl(action);\\\",\\n\\t\\t\\t\\\"\\\",\\n\\t\\t\\t\\\"    // Static Data\\\",\\n\\t\\t\\t\\\"    const reqPayload = requestObj(param);\\\",\\n\\t\\t\\t\\\"    let respData = null;\\\",\\n\\t\\t\\t\\\"\\\",\\n\\t\\t\\t\\\"    try {\\\",\\n\\t\\t\\t\\\"        const resp = await axiosRequest.${2:post}(url, reqPayload);\\\",\\n\\t\\t\\t\\\"        respData = resp.data;\\\",\\n\\t\\t\\t\\\"    } catch (error) {\\\",\\n\\t\\t\\t\\\"        throw error;\\\",\\n\\t\\t\\t\\\"    }\\\",\\n\\t\\t\\t\\\"\\\",\\n\\t\\t\\t\\\"    return respData;\\\",\\n\\t\\t\\t\\\"};\\\",\\n\\t\\t\\t\\\"\\\",\\n\\t\\t\\t\\\"export default Index;\\\"\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"React API: Axios\\\"\\n\\t},\\n\\t\\\"Lambda Get Item\\\": {\\n\\t\\t\\\"prefix\\\": \\\"getItem\\\",\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"getItem = async (props = {}) => {\\\",\\n\\t\\t\\t\\\"\\\",\\n\\t\\t\\t\\\"        const { data: { PK, SK } } = props;\\\",\\n\\t\\t\\t\\\"\\\",\\n\\t\\t\\t\\\"        const params = {\\\",\\n\\t\\t\\t\\\"            Key: marshall({\\\",\\n\\t\\t\\t\\\"                PK, SK\\\",\\n\\t\\t\\t\\\"            })\\\",\\n\\t\\t\\t\\\"        };\\\",\\n\\t\\t\\t\\\"\\\",\\n\\t\\t\\t\\\"        const res = await this.dbHelper.getItem(params);\\\",\\n\\t\\t\\t\\\"\\\",\\n\\t\\t\\t\\\"        const { requestId = -1 } = res[\\\\\\\"\\\\\\\\$metadata\\\\\\\"];\\\",\\n\\t\\t\\t\\\"\\\",\\n\\t\\t\\t\\\"        return {\\\",\\n\\t\\t\\t\\\"            ref: requestId,\\\",\\n\\t\\t\\t\\\"            data: unmarshall(res[\\\\\\\"Item\\\\\\\"])\\\",\\n\\t\\t\\t\\\"        };\\\",\\n\\t\\t\\t\\\"    }\\\"\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"Lambda Get Item\\\"\\n\\t},\\n\\t\\\"Lambda Add Item\\\": {\\n\\t\\t\\\"prefix\\\": \\\"additem\\\",\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"updateItem = async (props = {}) => {\\\",\\n\\t\\t\\t\\\"\\\",\\n\\t\\t\\t\\\"        const { data = \\\\\\\"\\\\\\\" } = props;\\\",\\n\\t\\t\\t\\\"\\\",\\n\\t\\t\\t\\\"        const { data: _item } = await this.getItem(props);\\\",\\n\\t\\t\\t\\\"\\\",\\n\\t\\t\\t\\\"        const params = {\\\",\\n\\t\\t\\t\\\"            Item: marshall({\\\",\\n\\t\\t\\t\\\"                ..._item,\\\",\\n\\t\\t\\t\\\"                ...data\\\",\\n\\t\\t\\t\\\"            })\\\",\\n\\t\\t\\t\\\"        };\\\",\\n\\t\\t\\t\\\"\\\",\\n\\t\\t\\t\\\"        const res = await this.dbHelper.updateItem(params);\\\",\\n\\t\\t\\t\\\"\\\",\\n\\t\\t\\t\\\"        const { requestId = -1 } = res[\\\\\\\"$metadata\\\\\\\"];\\\",\\n\\t\\t\\t\\\"\\\",\\n\\t\\t\\t\\\"        return {\\\",\\n\\t\\t\\t\\\"            ref: requestId,\\\",\\n\\t\\t\\t\\\"            msg: `${data.PK} Updated Successfully`\\\",\\n\\t\\t\\t\\\"        };\\\",\\n\\t\\t\\t\\\"    }\\\"\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"Lambda Add Item\\\"\\n\\t},\\n\\t\\\"Lambda Upload Image\\\": {\\n\\t\\t\\\"prefix\\\": \\\"uploadImg\\\",\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"uploadImg = async (props = {}) => {\\\",\\n\\t\\t\\t\\\"\\\",\\n\\t\\t\\t\\\"        const { event } = props;\\\",\\n\\t\\t\\t\\\"\\\",\\n\\t\\t\\t\\\"        const result = await parser.parse(event);\\\",\\n\\t\\t\\t\\\"\\\",\\n\\t\\t\\t\\\"        const file = result.files[0];\\\",\\n\\t\\t\\t\\\"\\\",\\n\\t\\t\\t\\\"        // Set up the parameters for S3 upload\\\",\\n\\t\\t\\t\\\"        const fileName = file.filename;\\\",\\n\\t\\t\\t\\\"        const fileData = Buffer.from(file.content, 'base64');\\\",\\n\\t\\t\\t\\\"        const contentType = file.contentType;\\\",\\n\\t\\t\\t\\\"\\\",\\n\\t\\t\\t\\\"        const s3Url = await this.s3Helper.upload(fileName, fileData, contentType);\\\",\\n\\t\\t\\t\\\"\\\",\\n\\t\\t\\t\\\"        return {\\\",\\n\\t\\t\\t\\\"            msg: `\\\\\\\\${fileName} uploaded successfully!`,\\\",\\n\\t\\t\\t\\\"            url: s3Url\\\",\\n\\t\\t\\t\\\"        }\\\",\\n\\t\\t\\t\\\"    }\\\"\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"Lambda Upload Image\\\"\\n\\t}\\n}\",\"javascriptreact.json\":\"{\\n\\t\\\"init\\\": {\\n\\t\\t\\\"prefix\\\": \\\"init\\\",\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"import { useState, useEffect } from \\\\\\\"react\\\\\\\";\\\",\\n\\t\\t\\t\\\"\\\",\\n\\t\\t\\t\\\"import { Container, Grid2, Typography, Button, Paper, IconButton, Box, Tooltip } from \\\\\\\"@mui/material\\\\\\\";\\\",\\n\\t\\t\\t\\\"import { GlobalStyles } from \\\\\\\"@config\\\\\\\";\\\",\\n\\t\\t\\t\\\"\\\",\\n\\t\\t\\t\\\"function Index(props) {\\\",\\n\\t\\t\\t\\\"    return (\\\",\\n\\t\\t\\t\\\"        <Grid2 container>\\\",\\n\\t\\t\\t\\\"            <Typography>This is Home Page</Typography>\\\",\\n\\t\\t\\t\\\"        </Grid2>\\\",\\n\\t\\t\\t\\\"    )\\\",\\n\\t\\t\\t\\\"}\\\",\\n\\t\\t\\t\\\"\\\",\\n\\t\\t\\t\\\"export default Index;\\\"\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"Create New Page\\\"\\n\\t},\\n\\t\\\"Region Comments\\\": {\\n\\t\\t\\\"prefix\\\": \\\"region\\\",\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"// #region ${1:region_name}\\\\r\\\",\\n\\t\\t\\t\\\"$TM_SELECTED_TEXT\\\\r\\\",\\n\\t\\t\\t\\\"// #endregion\\\"\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"description for Region Comments\\\"\\n\\t},\\n\\t\\\"React Redux\\\": {\\n\\t\\t\\\"prefix\\\": \\\"redux\\\",\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"import { useDispatch, useSelector } from 'react-redux';\\\\r\\\",\\n\\t\\t\\t\\\"import { Actions, Selectors } from '@libs/redux';\\\"\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"React Redux\\\"\\n\\t}\\n}\",\"json.json\":\"{\\n    \\\"Convert to SQL Select\\\": {\\n\\t\\t\\\"prefix\\\": \\\"select\\\",\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"{\\\",\\n\\t\\t\\t\\\"  \\\\\\\"type\\\\\\\": \\\\\\\"select\\\\\\\",\\\",\\n\\t\\t\\t\\\"  \\\\\\\"data\\\\\\\": ${TM_SELECTED_TEXT}\\\",\\n\\t\\t\\t\\\"}\\\"\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"Convert to SQL Select\\\"\\n\\t},\\n\\t\\\"Convert to Sql Insert\\\": {\\n\\t\\t\\\"prefix\\\": \\\"insert\\\",\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"{\\\",\\n\\t\\t\\t\\\"  \\\\\\\"type\\\\\\\": \\\\\\\"insert\\\\\\\",\\\",\\n\\t\\t\\t\\\"  \\\\\\\"data\\\\\\\": ${TM_SELECTED_TEXT}\\\",\\n\\t\\t\\t\\\"}\\\"\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"Convert to SQL Insert\\\"\\n\\t},\\n\\t\\\"Convert to SQL Update\\\": {\\n\\t\\t\\\"prefix\\\": \\\"update\\\",\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"{\\\",\\n\\t\\t\\t\\\"  \\\\\\\"type\\\\\\\": \\\\\\\"update\\\\\\\",\\\",\\n\\t\\t\\t\\\"  \\\\\\\"data\\\\\\\": ${TM_SELECTED_TEXT}\\\",\\n\\t\\t\\t\\\"}\\\"\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"Convert to SQL Update\\\"\\n\\t}\\n}\",\"jsonc.json\":\"{\\n\\t// Place your snippets for jsonc here. Each snippet is defined under a snippet name and has a prefix, body and \\n\\t// description. The prefix is what is used to trigger the snippet and the body will be expanded and inserted. Possible variables are:\\n\\t// $1, $2 for tab stops, $0 for the final cursor position, and ${1:label}, ${2:another} for placeholders. Placeholders with the \\n\\t// same ids are connected.\\n\\t// Example:\\n\\t// \\\"Print to console\\\": {\\n\\t// \\t\\\"prefix\\\": \\\"log\\\",\\n\\t// \\t\\\"body\\\": [\\n\\t// \\t\\t\\\"console.log('$1');\\\",\\n\\t// \\t\\t\\\"$2\\\"\\n\\t// \\t],\\n\\t// \\t\\\"description\\\": \\\"Log output to console\\\"\\n\\t// }\\n}\",\"jsonl.json\":\"{\\n\\t// Place your snippets for jsonl here. Each snippet is defined under a snippet name and has a prefix, body and \\n\\t// description. The prefix is what is used to trigger the snippet and the body will be expanded and inserted. Possible variables are:\\n\\t// $1, $2 for tab stops, $0 for the final cursor position, and ${1:label}, ${2:another} for placeholders. Placeholders with the \\n\\t// same ids are connected.\\n\\t// Example:\\n\\t// \\\"Print to console\\\": {\\n\\t// \\t\\\"prefix\\\": \\\"log\\\",\\n\\t// \\t\\\"body\\\": [\\n\\t// \\t\\t\\\"console.log('$1');\\\",\\n\\t// \\t\\t\\\"$2\\\"\\n\\t// \\t],\\n\\t// \\t\\\"description\\\": \\\"Log output to console\\\"\\n\\t// }\\n}\",\"jsx.json\":\"{\\n\\t// Place your snippets for jsx here. Each snippet is defined under a snippet name and has a prefix, body and \\n\\t// description. The prefix is what is used to trigger the snippet and the body will be expanded and inserted. Possible variables are:\\n\\t// $1, $2 for tab stops, $0 for the final cursor position, and ${1:label}, ${2:another} for placeholders. Placeholders with the \\n\\t// same ids are connected.\\n\\t// Example:\\n\\t// \\\"Print to console\\\": {\\n\\t// \\t\\\"prefix\\\": \\\"log\\\",\\n\\t// \\t\\\"body\\\": [\\n\\t// \\t\\t\\\"console.log('$1');\\\",\\n\\t// \\t\\t\\\"$2\\\"\\n\\t// \\t],\\n\\t// \\t\\\"description\\\": \\\"Log output to console\\\"\\n\\t// },\\n\\t\\\"React Native Button\\\": {\\n\\t\\t\\\"prefix\\\": \\\"btn\\\",\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"<TouchableOpacity style={{ width: \\\\\\\"60%\\\\\\\", height: 40 }}>\\\",\\n\\t\\t\\t\\\"    <View flex={1} backgroundColor={\\\\\\\"#F00\\\\\\\"}\\\",\\n\\t\\t\\t\\\"        alignItems={\\\\\\\"center\\\\\\\"} justifyContent={\\\\\\\"center\\\\\\\"}>\\\",\\n\\t\\t\\t\\\"        <Text style={{\\\",\\n\\t\\t\\t\\\"            fontSize: 14,\\\",\\n\\t\\t\\t\\\"            fontWeight: \\\\\\\"bold\\\\\\\",\\\",\\n\\t\\t\\t\\\"            color: \\\\\\\"#FFF\\\\\\\",\\\",\\n\\t\\t\\t\\\"        }}>${btnTitle}</Text>\\\",\\n\\t\\t\\t\\\"    </View>\\\",\\n\\t\\t\\t\\\"</TouchableOpacity>\\\"\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"React Native Button\\\"\\n\\t},\\n\\t\\\"React Empty Page\\\": {\\n\\t\\t\\\"prefix\\\": \\\"init_empty\\\",\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"<MPSGLayout>\\\",\\n\\t\\t\\t\\\"\\\\t<div className={\\\\\\\"h2\\\\\\\"}>This is ${name} Page</div>\\\",\\n\\t\\t\\t\\\"</MPSGLayout>\\\"\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"React Empty Page\\\"\\n\\t},\\n\\t\\\"Init Empty Page\\\": {\\n\\t\\t\\\"prefix\\\": \\\"init\\\",\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"<SafeAreaView style={{ flex: 1 }}>\\\\r\\\",\\n\\t\\t\\t\\\"            <View style={{ flex: 1 }}>\\\\r\\\",\\n\\t\\t\\t\\\"\\\\r\\\",\\n\\t\\t\\t\\\"                {/* Header */}\\\\r\\\",\\n\\t\\t\\t\\\"                <View style={{ height: 80 }} />\\\\r\\\",\\n\\t\\t\\t\\\"\\\\r\\\",\\n\\t\\t\\t\\\"                <View style={{ height: 10 }} />\\\\r\\\",\\n\\t\\t\\t\\\"\\\\r\\\",\\n\\t\\t\\t\\\"                {/* Body */}\\\\r\\\",\\n\\t\\t\\t\\\"                <ScrollView showsVerticalScrollIndicator={false}>\\\\r\\\",\\n\\t\\t\\t\\\"                    <VStack space={2}>\\\\r\\\",\\n\\t\\t\\t\\\"                    </VStack>\\\\r\\\",\\n\\t\\t\\t\\\"                </ScrollView>\\\\r\\\",\\n\\t\\t\\t\\\"\\\\r\\\",\\n\\t\\t\\t\\\"                {/* Footer */}\\\\r\\\",\\n\\t\\t\\t\\\"                <View style={{ height: 80 }} />\\\\r\\\",\\n\\t\\t\\t\\\"            </View>\\\\r\\\",\\n\\t\\t\\t\\\"        </SafeAreaView>\\\"\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"Init Empty Page\\\"\\n\\t}\\n}\",\"markdown.json\":\"{\\n    \\\"API Documentation\\\": {\\n        \\\"prefix\\\": [\\n            \\\"api_documentation\\\"\\n        ],\\n        \\\"body\\\": [\\n            \\\"## ${title}\\\",\\n            \\\"\\\",\\n            \\\"- URL: `${url}`\\\",\\n            \\\"\\\",\\n            \\\"### Headers\\\",\\n            \\\"\\\",\\n            \\\"```yaml\\\",\\n            \\\"```\\\",\\n            \\\"\\\",\\n            \\\"### Request\\\",\\n            \\\"\\\",\\n            \\\"```json\\\",\\n            \\\"```\\\",\\n            \\\"\\\",\\n            \\\"### Response\\\",\\n            \\\"\\\",\\n            \\\"```json\\\",\\n            \\\"```\\\"\\n        ],\\n        \\\"description\\\": \\\"Generate Simple API Documentation\\\"\\n\\t\\t},\\n\\t\\t\\\"Mermaid ERD Sample\\\": {\\n\\t\\t\\t\\\"prefix\\\": \\\"erd\\\",\\n\\t\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\t\\\"```mermaid\\\",\\n\\t\\t\\t\\t\\\"erDiagram\\\",\\n\\t\\t\\t\\t\\\"  TProduct {\\\",\\n\\t\\t\\t\\t\\\"    int ProductId PK\\\",\\n\\t\\t\\t\\t\\\"    string Title\\\",\\n\\t\\t\\t\\t\\\"    string Description\\\",\\n\\t\\t\\t\\t\\\"    float Price\\\",\\n\\t\\t\\t\\t\\\"    string Status\\\",\\n\\t\\t\\t\\t\\\"    date Last_Updated_Date\\\",\\n\\t\\t\\t\\t\\\"    string Last_Updated_By\\\",\\n\\t\\t\\t\\t\\\"  }\\\",\\n\\t\\t\\t\\t\\\"\\\",\\n\\t\\t\\t\\t\\\"  TOrderItem {\\\",\\n\\t\\t\\t\\t\\\"    int OrderItemId PK\\\",\\n\\t\\t\\t\\t\\\"    int OrderId FK\\\",\\n\\t\\t\\t\\t\\\"    int ProductId FK\\\",\\n\\t\\t\\t\\t\\\"  }\\\",\\n\\t\\t\\t\\t\\\"\\\",\\n\\t\\t\\t\\t\\\"  TOrder {\\\",\\n\\t\\t\\t\\t\\\"    int OrderId PK\\\",\\n\\t\\t\\t\\t\\\"    float Total\\\",\\n\\t\\t\\t\\t\\\"    string Status\\\",\\n\\t\\t\\t\\t\\\"    date Last_Updated_Date\\\",\\n\\t\\t\\t\\t\\\"    string Last_Updated_By\\\",\\n\\t\\t\\t\\t\\\"  }\\\",\\n\\t\\t\\t\\t\\\"\\\",\\n\\t\\t\\t\\t\\\"  TOrder ||--|{ TOrderItem : \\\\\\\"\\\\\\\"\\\",\\n\\t\\t\\t\\t\\\"  TProduct ||--|{ TOrderItem : \\\\\\\"\\\\\\\"\\\",\\n\\t\\t\\t\\t\\\"```\\\"\\n\\t\\t\\t],\\n\\t\\t\\t\\\"description\\\": \\\"Mermaid ERD Sample\\\"\\n\\t\\t},\\n\\t\\t\\\"proposal\\\": {\\n\\t\\t\\t\\\"prefix\\\": \\\"proposal\\\",\\n\\t\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\t\\\"# <Project-Name>\\\",\\n\\t\\t\\t\\t\\\"\\\",\\n\\t\\t\\t\\t\\\"## Scope\\\",\\n\\t\\t\\t\\t\\\"\\\",\\n\\t\\t\\t\\t\\\"<description>\\\",\\n\\t\\t\\t\\t\\\"\\\",\\n\\t\\t\\t\\t\\\"## Features\\\",\\n\\t\\t\\t\\t\\\"\\\",\\n\\t\\t\\t\\t\\\"## Technologies\\\",\\n\\t\\t\\t\\t\\\"\\\",\\n\\t\\t\\t\\t\\\"- Language: ?\\\",\\n\\t\\t\\t\\t\\\"- Framework: ?\\\",\\n\\t\\t\\t\\t\\\"- Database: ?\\\",\\n\\t\\t\\t\\t\\\"- Testing Framework: ?\\\",\\n\\t\\t\\t\\t\\\"- Local LLM: ?\\\",\\n\\t\\t\\t\\t\\\"\\\",\\n\\t\\t\\t\\t\\\"## ERD Diagram\\\",\\n\\t\\t\\t\\t\\\"\\\",\\n\\t\\t\\t\\t\\\"## API Workflow\\\",\\n\\t\\t\\t\\t\\\"\\\",\\n\\t\\t\\t\\t\\\"## App Directory\\\",\\n\\t\\t\\t\\t\\\"\\\",\\n\\t\\t\\t\\t\\\"<generate-using-tree-structure>\\\",\\n\\t\\t\\t\\t\\\"\\\",\\n\\t\\t\\t\\t\\\"## Notes / Remarks\\\"\\n\\t\\t\\t],\\n\\t\\t\\t\\\"description\\\": \\\"proposal\\\"\\n\\t\\t}\\n}\",\"neix-global.code-snippets\":\"{\\n\\t// Place your global snippets here. Each snippet is defined under a snippet name and has a scope, prefix, body and \\n\\t// description. Add comma separated ids of the languages where the snippet is applicable in the scope field. If scope \\n\\t// is left empty or omitted, the snippet gets applied to all languages. The prefix is what is \\n\\t// used to trigger the snippet and the body will be expanded and inserted. Possible variables are: \\n\\t// $1, $2 for tab stops, $0 for the final cursor position, and ${1:label}, ${2:another} for placeholders. \\n\\t// Placeholders with the same ids are connected.\\n\\t// Example:\\n\\t// \\\"Print to console\\\": {\\n\\t// \\t\\\"scope\\\": \\\"javascript,typescript\\\",\\n\\t// \\t\\\"prefix\\\": \\\"log\\\",\\n\\t// \\t\\\"body\\\": [\\n\\t// \\t\\t\\\"console.log('$1');\\\",\\n\\t// \\t\\t\\\"$2\\\"\\n\\t// \\t],\\n\\t// \\t\\\"description\\\": \\\"Log output to console\\\"\\n\\t// }\\n\\t\\\"Global snippets\\\": {\\n\\t\\t\\\"prefix\\\": [\\\"const\\\"],\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"@rF!12e45\\\",\\n\\t\\t\\t\\\"root\\\"\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"Description for Global Snippets\\\"\\n\\t},\\n\\t\\\"Snippet\\\": {\\n\\t\\t\\\"prefix\\\": [\\n\\t\\t\\t\\\"snip\\\"\\n\\t\\t],\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"\\\\\\\"${1:Snippet Name}\\\\\\\": {\\\\r\\\",\\n\\t\\t\\t\\\"\\\\t\\\\\\\"prefix\\\\\\\": [\\\\\\\"${2:Prefix}\\\\\\\"],\\\\r\\\",\\n\\t\\t\\t\\\"\\\\t\\\\\\\"body\\\\\\\": [\\\\r\\\",\\n\\t\\t\\t\\\"\\\\t\\\\t\\\\\\\"${3:Content}\\\\\\\"\\\\r\\\",\\n\\t\\t\\t\\\"\\\\t],\\\\r\\\",\\n\\t\\t\\t\\\"\\\\t\\\\\\\"description\\\\\\\": \\\\\\\"${1:Snippet Name}\\\\\\\"\\\\r\\\",\\n\\t\\t\\t\\\"}\\\"\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"Description for Global Snippets\\\"\\n\\t},\\n\\t\\\"Current File Path\\\": {\\n\\t\\t\\\"prefix\\\": \\\"fp\\\",\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"$TM_FILEPATH\\\"\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"Get Current File Path\\\"\\n\\t},\\n\\t\\\"File Header Date\\\": {\\n\\t\\t\\\"prefix\\\": \\\"date\\\",\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"$CURRENT_YEAR-$CURRENT_MONTH-$CURRENT_DATE\\\"\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"Output a file header with the file name and date\\\"\\n\\t},\\n\\t\\\"File Header DateTime\\\": {\\n\\t\\t\\\"prefix\\\": \\\"datetime\\\",\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"$CURRENT_YEAR-$CURRENT_MONTH-$CURRENT_DATE $CURRENT_HOUR