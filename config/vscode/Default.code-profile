t\\\",\\n\\t\\t\\t\\\"              properties:\\\",\\n\\t\\t\\t\\\"                name:\\\",\\n\\t\\t\\t\\\"                  type: string\\\",\\n\\t\\t\\t\\\"                  example: morpheus\\\",\\n\\t\\t\\t\\\"                job:\\\",\\n\\t\\t\\t\\\"                  type: string\\\",\\n\\t\\t\\t\\\"                  example: leader\\\",\\n\\t\\t\\t\\\"        required: true\\\",\\n\\t\\t\\t\\\"      responses:\\\",\\n\\t\\t\\t\\\"        '200':\\\",\\n\\t\\t\\t\\\"          description: Success\\\",\\n\\t\\t\\t\\\"          content:\\\",\\n\\t\\t\\t\\\"            application/json:\\\",\\n\\t\\t\\t\\\"              schema:\\\",\\n\\t\\t\\t\\\"                type: object\\\",\\n\\t\\t\\t\\\"                properties:\\\",\\n\\t\\t\\t\\\"                  createdAt:\\\",\\n\\t\\t\\t\\\"                    type: string\\\",\\n\\t\\t\\t\\\"                    example: '2024-07-05T03:37:53.656Z'\\\",\\n\\t\\t\\t\\\"                  name:\\\",\\n\\t\\t\\t\\\"                    type: string\\\",\\n\\t\\t\\t\\\"                    example: morpheus\\\",\\n\\t\\t\\t\\\"                  id:\\\",\\n\\t\\t\\t\\\"                    type: string\\\",\\n\\t\\t\\t\\\"                    example: '586'\\\",\\n\\t\\t\\t\\\"                  job:\\\",\\n\\t\\t\\t\\\"                    type: string\\\",\\n\\t\\t\\t\\\"                    example: leader\\\",\\n\\t\\t\\t\\\"        '400':\\\",\\n\\t\\t\\t\\\"          description: Error\\\",\\n\\t\\t\\t\\\"          content:\\\",\\n\\t\\t\\t\\\"            application/json:\\\",\\n\\t\\t\\t\\\"              schema:\\\",\\n\\t\\t\\t\\\"                type: object\\\",\\n\\t\\t\\t\\\"                properties:\\\",\\n\\t\\t\\t\\\"                  error:\\\",\\n\\t\\t\\t\\\"                    type: string\\\",\\n\\t\\t\\t\\\"    parameters: []\\\",\\n\\t\\t\\t\\\"components:\\\",\\n\\t\\t\\t\\\"  schemas:\\\",\\n\\t\\t\\t\\\"    User:\\\",\\n\\t\\t\\t\\\"      type: object\\\",\\n\\t\\t\\t\\\"      properties:\\\",\\n\\